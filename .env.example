# ----------------------------------------------------------------------------
# Database (PostgreSQL) — use Supabase or Neon
# ----------------------------------------------------------------------------
# Pooled connection string used by the app at runtime (PgBouncer / pooler).
# The extra params make the pooled connection resilient (avoids cold-start init errors).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20&connect_timeout=15"
# Direct connection used by Prisma migrate / db push (non-pooled).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ----------------------------------------------------------------------------
# NextAuth / Auth.js
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
# Local dev URL. On Vercel this is set automatically.
AUTH_URL="http://localhost:3000"
# Trust the host header (required on Vercel / proxies).
AUTH_TRUST_HOST="true"

# ----------------------------------------------------------------------------
# Seed credentials (used by prisma/seed.ts)
# ----------------------------------------------------------------------------
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="Admin@12345"
